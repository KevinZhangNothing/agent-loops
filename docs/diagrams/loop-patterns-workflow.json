    {
      "id": "ci-fix",
      "lane": "ci",
      "col": 4,
      "type": "backend",
      "label": "Fix PR",
      "sublabel": "worktree"
    },
    {
      "id": "dep-scan",
      "lane": "dep",
      "col": 0,
      "type": "backend",
      "label": "Scan",
      "sublabel": "deps"
    },
    {
      "id": "dep-select",
      "lane": "dep",
      "col": 2,
      "type": "backend",
      "label": "Select",
      "sublabel": "patch"
    },
    {
      "id": "dep-pr",
      "lane": "dep",
      "col": 4,
      "type": "backend",
      "label": "PR",
      "sublabel": "allowlist"
