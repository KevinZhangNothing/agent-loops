  "edges": [
    { "from": "triage-trigger", "to": "triage-scan", "variant": "emphasis" },
    { "from": "triage-scan", "to": "triage-report", "variant": "emphasis" },
    { "from": "pr-watch", "to": "pr-check", "variant": "emphasis" },
    { "from": "pr-check", "to": "pr-update", "variant": "emphasis" },
    { "from": "ci-detect", "to": "ci-analyze", "variant": "emphasis" },
    { "from": "ci-analyze", "to": "ci-fix", "variant": "emphasis" },
    { "from": "dep-scan", "to": "dep-select", "variant": "emphasis" },
    { "from": "dep-select", "to": "dep-pr", "variant": "emphasis" }
  ],
  "cards": [
    {
      "dot": "cyan",
      "title": "L1 Patterns",
      "items": ["Report only", "No code changes", "Human decides"]
    },
    {
      "dot": "violet",
      "title": "L2 Patterns",
      "items": ["Creates PRs", "Verifier", "Human merges"]
    },
    {
      "dot": "amber",
      "title": "Safety Gates",
      "items": ["Worktrees", "loop-verifier", "Circuit breaker"]
    },
    {
      "dot": "emerald",
      "title": "Token Budget",
      "items": ["Early exit", "Cost tracking", "Cadence"]
    }
  ]
}
