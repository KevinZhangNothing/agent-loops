{
  "name": "@kevinzhangnothing/loop-init",
  "version": "1.3.3",
  "description": "Scaffold loop engineering patterns and starters into any project. Supports Grok, Claude Code, Codex, Opencode and more. npx @kevinzhangnothing/loop-init . --pattern daily-triage --tool opencode",
  "type": "module",
  "bin": {
    "loop-init": "./dist/cli.js"
  },
  "files": [
    "dist",
    "starters",
    "templates",
    "README.md"
  ],
  "scripts": {
    "bundle": "node scripts/bundle-assets.mjs",
    "build": "npm run bundle && tsc",
    "test": "npm run build && node --test test/cli.test.mjs",
    "prepublishOnly": "npm test",
    "start": "node dist/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "loop-engineering",
    "ai-agents",
    "coding-agents",
    "scaffold",
    "starter",
    "claude-code",
    "grok",
    "codex",
    "opencode",
    "github-actions",
    "patterns"
  ],
  "author": "Kevin Zhang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KevinZhangNothing/loop-engineering.git",
    "directory": "tools/loop-init"
  },
  "homepage": "https://KevinZhangNothing.github.io/loop-engineering/",
  "bugs": {
    "url": "https://github.com/KevinZhangNothing/loop-engineering/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@kevinzhangnothing/loop-audit": "^1.5.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  }
}