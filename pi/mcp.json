{
  "$schema": "https://pi.mcp.dev/schema/mcp.json",
  "description": "Agent Loops MCP 配置 — 用于 pi 集成",
  "mcpServers": {
    "LoopEngineering": {
      "command": "npx",
      "args": ["-y", "@kevinzhangnothing/loop-mcp-server"],
      "env": {
        "LOOP_PROJECT_ROOT": "${LOOP_PROJECT_ROOT:-.}"
      },
      "description": "Agent Loops MCP 服务器 — 提供 patterns、skills、state 查询与 cost 估算",
      "resources": [
        "loop://registry",
        "loop://config",
        "loop://budget",
        "loop://run-log",
        "loop://safety",
        "loop://patterns/*",
        "loop://skills/*",
        "loop://state/*"
      ],
      "tools": [
        "loop_list_patterns",
        "loop_list_skills",
        "loop_list_state_files",
        "loop_get_pattern",
        "loop_get_skill",
        "loop_get_state",
        "loop_recommend_pattern",
        "loop_estimate_cost"
      ]
    }
  },
  "shortcuts": {
    "+loop-score": {
      "description": "运行 loop-audit 审计当前项目",
      "command": "npx @kevinzhangnothing/loop-audit ."
    },
    "+loop-score-suggest": {
      "description": "运行 loop-audit 并获取改进建议",
      "command": "npx @kevinzhangnothing/loop-audit . --suggest"
    },
    "+loop-score-json": {
      "description": "运行 loop-audit 输出 JSON",
      "command": "npx @kevinzhangnothing/loop-audit . --json"
    },
    "+loop-badge": {
      "description": "生成 README 徽章",
      "command": "npx @kevinzhangnothing/loop-audit . --badge"
    },
    "+loop-init": {
      "description": "初始化 Loop 脚手架",
      "command": "npx @kevinzhangnothing/loop-init . --pattern daily-triage --tool claude"
    },
    "+loop-init-dry-run": {
      "description": "预览 Loop 脚手架生成",
      "command": "npx @kevinzhangnothing/loop-init . --pattern daily-triage --tool claude --dry-run"
    },
    "+loop-cost": {
      "description": "估算 Loop token 花费",
      "command": "npx @kevinzhangnothing/loop-cost --pattern daily-triage --level L1"
    },
    "+loop-cost-json": {
      "description": "估算 Loop token 花费（JSON）",
      "command": "npx @kevinzhangnothing/loop-cost --pattern daily-triage --level L1 --json"
    },
    "+loop-state": {
      "description": "查看当前 STATE.md 内容",
      "command": "cat STATE.md 2>/dev/null || echo 'No STATE.md found'"
    },
    "+loop-log": {
      "description": "查看最近的 loop 运行日志",
      "command": "tail -20 loop-run-log.md 2>/dev/null || echo 'No loop-run-log.md found'"
    }
  },
  "variables": {
    "LOOP_PROJECT_ROOT": {
      "description": "Loop 项目根目录",
      "default": ".",
      "prompt_user": false
    }
  }
}
